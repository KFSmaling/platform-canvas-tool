{
  "name": "platform-canvas-tool",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.27",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.19",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "REACT_APP_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) REACT_APP_VERSION=$(node -p \"require('./package.json').version\") react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "react/jsx-no-literals": [
        "warn",
        {
          "noStrings": false,
          "ignoreProps": true,
          "noAttributeStrings": false,
          "allowedStrings": [
            "·",
            " · ",
            "—",
            "–",
            "/",
            ":",
            "…",
            "...",
            "✓",
            "✗",
            "✕",
            "✔",
            "←",
            "→",
            "↑",
            "↓",
            "&",
            "&amp;",
            "(",
            ")",
            "[",
            "]",
            "{",
            "}",
            "•",
            "›",
            "‹",
            "+",
            "-",
            "?",
            "!",
            "|"
          ]
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0"
  }
}
